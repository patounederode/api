---
import Layout from "../layouts/Layout.astro";
---

<meta charset="UTF-8" />

<h1>My Favorites</h1>
<a href="/">← Back</a>


<ul id="favorites-list"></ul>

<Layout>


<script>
  // chatgpt
  // Haal favorieten op uit localStorage
  let favorites = JSON.parse(localStorage.getItem("favorites")) || [];

  // Pakt het HTML-element de lijst wordt ingezet
  const list = document.getElementById("favorites-list");

  // Favorieten tonen op de pagina
  function renderFavorites() {
    list.innerHTML = "";

    // Check of er geen favorieten zijn
    if (favorites.length === 0) {
      list.innerHTML = "<p>You have no favorites yet.</p>";
      return;
    }

    // Loop door alle favorieten heen, art = favoriet item, index = nummer in de lijst
    favorites.forEach((art, index) => {
      // Maak een nieuw list-item (<li>) aan
      const li = document.createElement("li");

      // Zet inhoud in het <li>
      li.innerHTML = `
  <h2>${art.title}</h2>

  ${
    art.image
      ? `
        <a href="https://www.artic.edu/artworks/${art.id}" target="_blank" rel="noopener noreferrer">
          <img src="https://www.artic.edu/iiif/2/${art.image}/full/300,/0/default.jpg" />
        </a>
      `
      : ""
  }

  <br />

  <button id="delete-${index}">Delete</button>
`;

      // Zet het item op de pagina
      list.appendChild(li);

      const btn = document.getElementById(`delete-${index}`);

      // Als je op de knop klikt:
      btn.addEventListener("click", () => {
        // Verwijder 1 item op deze plek
        favorites.splice(index, 1);

        // Slaat de nieuwe lijst op in localStorage
        localStorage.setItem("favorites", JSON.stringify(favorites));

        // Laat de lijst zien
        renderFavorites();
      });
    });
  }

  // Laat favorieten zien bij het laden van de pagina
  renderFavorites();
</script>






<style>
  @font-face {
    font-family: "Playfair";
    src: url("/fonts/PlayfairDisplay-VariableFont_wght.ttf");
  }

  @font-face {
    font-family: "Red";
    src: url("/fonts/Redhatdisplay-VariableFont_wght.ttf");
  }

  @font-face {
    font-family: "Script";
    src: url("/fonts/ImperialScript-Regular.ttf");
  }

  body {
    margin: 0;
    width: 100%;
    height: 100%;
    font-family: "Red";
    background-color: #fff9ed;
    color: rgb(56, 56, 56);
    text-align: center;
  }

  a {
    color: #488b52;
    &:hover {
      color: #ff7171;
      transform: scale(1.1);
    }
  }
  h1 {
    font-family: "Playfair", serif;
    display: flex;
    justify-self: center;
    font-size: 2.5em;
    color: #488b52;
  }

  :global(#favorites-list) {
    max-width: 100%;
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4em;
    margin: 2em;
    padding: 2em;
    font-size: 0.8em;
  }

  :global(#favorites-list img) {
    width: 100%;
    height: auto;
    border-radius: 1em;
    object-fit: cover;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
  }

  :global(#favorites-list a) {
    color: #488b52;
  }

  :global(#favorites-list button) {
    margin-top: 0.5em;
    padding: 0.5em 1em;
    background-color: #ff7171;
    color: white;
    border: none;
    border-radius: 0.5em;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(201, 124, 93, 0.4);

    &:hover {
      transform: scale(1.1);
      background-color: #ff1a1a;
    }
  }
</style>
</Layout>