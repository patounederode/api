---
import Layout from "../layouts/Layout.astro";
---

<meta charset="UTF-8" />
  
</Layout>
<h1>Create Artwork</h1>
<a href="/">← Back</a>

<div style="margin:10px 0;">
  <label>Color: </label>
  <input type="color" id="color" value="#000000" />

  <label style="margin-left:10px;">Size: </label>
  <input type="range" id="size" min="1" max="20" value="5" />

  <canvas id="canvas" width="600" height="400" style="border:1px solid black;"></canvas>

  <button onclick="clearCanvas()" class="deletebtn">Delete</button>
</div>


<!-- Chatgpt -->
<!-- https://developer.mozilla.org/en-US/docs/Web/API/Canvas_API -->
 <!-- https://developer.mozilla.org/en-US/docs/Web/API/Window/load_event -->
  <!-- ctx - context, pen waarmee je tekent  -->
<script>
  window.onload = function () {
    // Wacht tot de hele pagina klaar is

    const canvas = document.getElementById("canvas");

    // 2D tekenvlak (canvas om op te tekenen)
    const ctx = canvas.getContext("2d");

    // gekozen kleur
    const color = document.getElementById("color");

    // dikte van de lijn
    const size = document.getElementById("size");

    // teken aan/uit
    let drawing = false;

    // bewaart positie van de muis, nodig om een lijn te maken
    let lastX = 0;
    let lastY = 0;

    canvas.onmousedown = function (e) {
      // Start met tekenen als je muis indrukt
      //  e is event, waar de muis is
      drawing = true;

    
    };

    canvas.onmouseup = function () {
      // Stop met tekenen als je loslaat
      drawing = false;
    };

    canvas.onmousemove = function (e) {
      // Alleen tekenen als muis ingedrukt is
      if (drawing) {
        let rect = canvas.getBoundingClientRect();

        let x = e.clientX - rect.left;
        let y = e.clientY - rect.top;

        ctx.strokeStyle = color.value; // kleur van de lijn
        ctx.lineWidth = size.value; // dikte van de lijn

        ctx.beginPath(); // start nieuwe lijn

        ctx.moveTo(lastX, lastY); // beginpunt
        ctx.lineTo(x, y); // eindpunt

        ctx.stroke(); // teken de lijn

        // update positie
        lastX = x;
        lastY = y;
      }
    };

    window.clearCanvas = function () {
      // Wist het hele canvas
      ctx.clearRect(0, 0, canvas.width, canvas.height);
    };
  };
</script>

<style>
  @font-face {
    font-family: "Playfair";
    src: url("/fonts/PlayfairDisplay-VariableFont_wght.ttf");
  }

  @font-face {
    font-family: "Red";
    src: url("/fonts/Redhatdisplay-VariableFont_wght.ttf");
  }

  @font-face {
    font-family: "Script";
    src: url("/fonts/ImperialScript-Regular.ttf");
  }
  body {
  margin: 0;
  width: 100%;
  height: 100%;
  font-family: 'Red';
  background-color: #fff9ed;
  color: rgb(56, 56, 56);
  padding: 1em;
  display: grid;
  justify-content: center;
  text-align: center;
}

h1 {
  font-family: 'Playfair', serif;
  font-size: 2.5em;
  color: rgb(72, 139, 82);
  text-align: center;
}

p {
  font-size: 1.2em;
  text-align: center;
  margin-top: -1em;
  margin-bottom: 2em;
}

  a {
    color: #488b52;
    &:hover {
      color: #ff7171;
      transform: scale(1.1);
    }
  }
  
  input[type="color"] {
    font-family: "Red";
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    background: none;
    padding: 0;
  }

  input[type="range"] {
    padding: 2em;
  }

  /* kleur/grootte aligned */
  input[type="color"],
  input[type="range"],
  #sizeValue {
    vertical-align: middle;
  }

  .deletebtn {
    margin-left: 10px;
    padding: 5px 10px;
    background-color: #ff4d4d;
    color: white;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    display: flex;
    align-self: center;
    justify-self: center;
    margin: 2em;
  }
  .deletebtn:hover {
    transform: scale(1.1);
    background-color: #ff1a1a;
  }

  #canvas {
    display: flex;
    border-radius: 20px;
    background-color: white;

    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);

    cursor: crosshair;

    justify-self: center;
    align-self: center;
  }
</style>
