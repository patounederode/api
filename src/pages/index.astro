---
import Layout from '../layouts/Layout.astro';

const response = await fetch("https://api.artic.edu/api/v1/artworks?page=1&limit=10");
// fetch, haalt data op 
const data = await response.json();
// await, wacht tot de data binnen is
// response.json()  zet de response om naar een JavaScript object
const artworks = data.data || [];
// data.data → daar zitten de kunstwerken in
// || [] → fallback: als er geen data is, gebruik een lege array om errors te voorkomen
---
<meta charset="UTF-8" />


<h1>Digital Art Gallery</h1>
<p>Discover art. Save inspiration. Create your own.</p>

<a href="/detail">Create Artwork</a>
<a href="/favorites">Go to Favorites</a>


<ul id="favorites-list">
  {artworks.map((art) => (
    // Voor elk kunstwerk (art) maak je HTML die de titel, afbeelding en een favoriet-knop bevat

<li>
  {/* <h2>{art.title}</h2> */}

  {art.image_id && (
    // de unieke ID die nodig is om de afbeelding op te halen
    // && → alleen als art.image_id bestaat (anders niks tonen)
    <img 
      src={`https://www.artic.edu/iiif/2/${art.image_id}/full/300,/0/default.jpg`} 
      alt={art.title} 
    />
  )}

  <button class="fav-btn" data-id={art.id} data-title={art.title} data-image={art.image_id}>
  </button>
</li>

  ))}

</ul>


<script>
  // Haalt opgeslagen favorieten op uit localStorage (browser opslag)
  // Als er nog niets is opgeslagen, wordt een lege array gebruikt
  let favorites = JSON.parse(localStorage.getItem("favorites") || "[]");

  // Selecteert alle knoppen met de class "fav-btn"
  const buttons = document.querySelectorAll(".fav-btn");

  // Functie die de tekst van de knop aanpast afhankelijk van status
  function updateButton(btn, isFav) {
    if (isFav) {
      btn.textContent = "❤️ Saved";
    } else {
      btn.textContent = "🤍 Favorite";
    }
  }

  // Loopt door alle favorieten knoppen heen
  buttons.forEach((btn) => {

    // Haalt data op uit de HTML (data-id, data-title, data-image)
    const id = btn.dataset.id;
    const title = btn.dataset.title;
    const image = btn.dataset.image;

    // Controleert of dit item al in de favorieten zit
    const exists = favorites.some(item => item.id === id);

    // Zet de juiste knoptekst bij het laden van de pagina
    updateButton(btn, exists);

    // Als er op de knop wordt geklikt
    btn.addEventListener("click", () => {

      // Opnieuw controleren of het item al bestaat
      const exists = favorites.some(item => item.id === id);

      if (!exists) {
        // Voeg item toe aan favorieten
        favorites.push({ id, title, image });

        // Update knoptekst naar "Saved"
        updateButton(btn, true);
      } else {
        // Verwijder item uit favorieten
        favorites = favorites.filter(item => item.id !== id);

        // Update knoptekst naar "Favorite"
        updateButton(btn, false);
      }

      // Sla de nieuwe favorietenlijst op in localStorage
      localStorage.setItem("favorites", JSON.stringify(favorites));

      // Voeg visuele active class toe (bijv. animatie in CSS)
      btn.classList.add("active");

      // Verwijder de active class na 200 milliseconden
      setTimeout(() => {
        btn.classList.remove("active");
      }, 200);
    });

    
  });
</script>



<style>

