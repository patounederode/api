---
import Layout from '../layouts/Layout.astro';

const response = await fetch("https://api.artic.edu/api/v1/artworks?page=1&limit=10");
const data = await response.json();
const artworks = data.data || [];
---
<meta charset="UTF-8" />
<h1>Kunstwerken</h1>

<a href="/detail">Maak kunstwerk</a>
<a href="/favorites">Ga naar favorieten</a>



<ul id="favorites-list">
  {artworks.map((art) => (
<li>
  <h2>{art.title}</h2>

  {art.image_id && (
    <img 
      src={`https://www.artic.edu/iiif/2/${art.image_id}/full/300,/0/default.jpg`} 
      alt={art.title} 
    />
  )}

  <button class="fav-btn" data-id={art.id} data-title={art.title} data-image={art.image_id}>
     Favoriet ❤️
  </button>
</li>

  ))}
</ul>

<!--   // JSON.stringify(object) -> object naar string
  // JSON.parse(string) -> string naar object
 -->

<script>
  let favorites = JSON.parse(localStorage.getItem("favorites")) || [];

  const buttons = document.querySelectorAll(".fav-btn");

  function updateButton(btn, isFav) {
    btn.textContent = isFav ? "❤️ Opgeslagen" : "🤍 Favoriet";
  }

  buttons.forEach((btn) => {
    const id = btn.dataset.id;

    // initial state
    const exists = favorites.find(item => item.id === id);
    updateButton(btn, !!exists);

    btn.addEventListener("click", () => {
      const title = btn.dataset.title;
      const image = btn.dataset.image;

      const exists = favorites.find(item => item.id === id);

      if (!exists) {
        favorites.push({ id, title, image });
        updateButton(btn, true);
      } else {
        favorites = favorites.filter(item => item.id !== id);
        updateButton(btn, false);
      }

      localStorage.setItem("favorites", JSON.stringify(favorites));

      // animatie
      btn.classList.add("active");
      setTimeout(() => btn.classList.remove("active"), 200);
    });
  });
</script>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	h1 {
		font-family: Arial, Helvetica, sans-serif;
		display: flex;
		justify-self: center;
	}

  ul {
	  font-size: 0.8em;
	  font-family: Arial, Helvetica, sans-serif;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;
    list-style-type: none;
    padding: 2em;
  }

  li {
    border: 1px solid #ddd;
    padding: 10px;
    border-radius: 10px;
  }

  img {
    max-width: 100%;
    display: block;
    border-radius: 8px;
  }

  button {
	display: flex;
	justify-self: center;
    padding:1em;
	border-radius: 1em;
	background-color: hsl(328, 100%, 87%);
	border: none;
	margin-top: 1em;
    cursor: pointer;
  }

  a {
  padding: 1em;
    justify-items: center;
    align-items: center;
    
  }

    a:hover {
    color: hotpink;
  }

.fav-btn {
  transition: transform 0.2s ease;
}

.fav-btn.active ul{
  transform: scale(1.3);
}
  
</style>
