---
import Layout from "../../layouts/Layout.astro";
const art = Astro.params.art;
const response = await fetch(
  "https://api.artic.edu/api/v1/artworks/" + art
);
const data = await response.json();
const artwork = data.data; 

---
<Layout>
  <h1>{artwork.title}</h1>
  <h2>{artwork.artist_title} ({artwork.date_display})</h2>
  
  <a href="/">← Back to all artworks</a>

  {artwork.image_id && (
    <img
      src={`https://www.artic.edu/iiif/2/${artwork.image_id}/full/800,/0/default.jpg`}
      alt={`Artwork titled ${artwork.title} by ${artwork.artist_title}`}
    />
  )}

  <ul>
    <li><strong>Medium:</strong> {artwork.medium_display}</li>
    <li><strong>Dimensions:</strong> {artwork.dimensions}</li>
    <li><strong>Classification:</strong> {artwork.classification_titles?.join(", ")}</li>
    <li><strong>Credit Line:</strong> {artwork.credit_line}</li>
    <li><strong>Origin:</strong> {artwork.place_of_origin}</li>
  </ul>

  {artwork.artist_display && (
    <section>
      <h3>About the artist</h3>
      <p>{artwork.artist_display}</p>
    </section>
  )}
</Layout>




<style>

@font-face {
  font-family: 'Playfair';
  src: url('/fonts/PlayfairDisplay-VariableFont_wght.ttf');
}

@font-face {
  font-family: 'Red';
  src: url('/fonts/Redhatdisplay-VariableFont_wght.ttf');
}

@font-face {
  font-family: 'Script';
  src: url('/fonts/ImperialScript-Regular.ttf');
}

body {
  margin: 0;
  width: 100%;
  height: 100%;
  font-family: 'Red';
  background-color: #fff9ed;
  color: rgb(56, 56, 56);
  padding: 1em;
  display: grid;
  justify-content: center;
  text-align: center;
}

h1 {
  font-family: 'Playfair', serif;
  font-size: 2.5em;
  color: #488b52;
  text-align: center;
}

p {
  font-size: 1.2em;
  justify-self: center;
  margin-bottom: 0;
  display: flex;
color:#488b52 ;
}


img {
  display: flex;
  justify-self: center;
  margin: 2em;
border-radius: 1em;
width: 300px;
box-shadow: 0px 5px 20px rgba(0, 0, 0, 0.154);
}
a {
  text-decoration: none;
  color: #488b52;
  &:hover {
      color: #ff7171;
      transform: scale(1.1);
      transition: 0.5s;
    }
  
}

ul li {
  text-align: left;
  text-decoration: none;
  color: #488b52;
}
</style>