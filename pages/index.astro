---
const response = await fetch("https://api.artic.edu/api/v1/artworks?page=1&limit=10");
const data = await response.json();
const artworks = data.data || [];
---
<meta charset="UTF-8" />
<h1>Kunstwerken</h1>


<ul>
  {artworks.map((art) => (
<li>
  <h2>{art.title}</h2>

  {art.image_id && (
    <img 
      src={`https://www.artic.edu/iiif/2/${art.image_id}/full/300,/0/default.jpg`} 
      alt={art.title} 
    />
  )}

  <button data-id={art.id} data-title={art.title} data-image={art.image_id}>
     Favoriet ❤️
  </button>
</li>

  ))}
</ul>



<script>

  // JSON.stringify(object) -> object naar string
  // JSON.parse(string) -> string naar object

  // haal bestaande favorites op (of lege lijst)
  let favorites = JSON.parse(localStorage.getItem("favorites")) || [];

  // selecteer alle knoppen
  const buttons = document.querySelectorAll("button");

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = btn.dataset.id;
      const title = btn.dataset.title;
      const image = btn.dataset.image;

      // check of al bestaat
      const exists = favorites.find(item => item.id === id);

      if (!exists) {
        favorites.push({ id, title, image });
        localStorage.setItem("favorites", JSON.stringify(favorites));

        btn.textContent = "❤️ Opgeslagen";
      } else {
        btn.textContent = "❤️ Al toegevoegd";
      }
    });
  });
</script>



<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	h1 {
		font-family: Arial, Helvetica, sans-serif;
		display: flex;
		justify-self: center;
	}
  
  ul {
	  font-size: 0.8em;
	  font-family: Arial, Helvetica, sans-serif;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;
    list-style-type: none;
    padding: 0;
  }

  li {
    border: 1px solid #ddd;
    padding: 10px;
    border-radius: 10px;
  }

  img {
    max-width: 100%;
    display: block;
    border-radius: 8px;
  }

  button {
	display: flex;
	justify-self: center;
    padding:1em;
	border-radius: 1em;
	background-color: #ff83c5;
	border: none;
	margin-top: 1em;
    cursor: pointer;
  }
  
</style>
